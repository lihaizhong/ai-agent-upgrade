{
  "skill_name": "rag-learning",
  "version": "1.1.1",
  "evals": [
    {
      "id": 1,
      "name": "学习课程-基础入门分流",
      "prompt": "我想学习 RAG 搭建，从基础开始",
      "expected_output": "应该路由到学习课程，先判断用户基础，再推荐少量起始课程，而不是一次展示全部内容",
      "files": [],
      "assertions": [
        {"type": "contains_any", "value": ["基础", "入门", "起点", "零基础"]},
        {"type": "contains_any", "value": ["课程", "01", "02", "03"]},
        {"type": "contains_any", "value": ["推荐", "先学", "建议从", "学习路径"]}
      ]
    },
    {
      "id": 2,
      "name": "实战搭建-客服机器人分流",
      "prompt": "我要搭建一个客服机器人 RAG 系统",
      "expected_output": "应该路由到实战搭建，先确认关键约束，再只推进一个核心决策，不应一次性输出完整大而全方案",
      "files": [],
      "assertions": [
        {"type": "contains_any", "value": ["客服机器人", "实战", "搭建"]},
        {"type": "contains_any", "value": ["场景", "数据", "预算", "部署", "语言"]},
        {"type": "contains_any", "value": ["当前决策", "推荐方案", "下一步", "先确认"]}
      ]
    },
    {
      "id": 3,
      "name": "专题问答-Embedding模型选择",
      "prompt": "如何选择 Embedding 模型？",
      "expected_output": "应该直接进入专题问答，先给结论和选择标准，不应先要求用户在学习或实战模式中做选择",
      "files": [],
      "assertions": [
        {"type": "contains", "value": "Embedding"},
        {"type": "contains_any", "value": ["语言", "成本", "精度", "部署"]},
        {"type": "contains_any", "value": ["结论", "推荐", "适合", "选择标准"]}
      ]
    },
    {
      "id": 4,
      "name": "专题问答-向量数据库选型",
      "prompt": "我想了解向量数据库有哪些选择",
