      "files": [],
      "assertions": [
        {"type": "contains_any", "value": ["向量数据库", "Chroma", "Qdrant", "Milvus", "Pinecone"]},
        {"type": "contains_any", "value": ["规模", "预算", "部署", "过滤"]},
        {"type": "contains_any", "value": ["建议", "适合", "默认", "起步"]}
      ]
    },
    {
      "id": 5,
      "name": "专题问答-RAG与微调对比",
      "prompt": "RAG 和微调有什么区别？什么时候用哪个？",
      "expected_output": "应该直接解释区别、适用场景与推荐选择，不应强行切回课程模式",
      "files": [],
      "assertions": [
        {"type": "contains", "value": "RAG"},
